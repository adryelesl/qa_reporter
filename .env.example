# Email Settings (for sending reports)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=yor_smtp_key
SENDER_EMAIL=your_email@gmail.com
RECIPIENT_EMAIL=destination_mail@exemplo.com

# Jira Settings (for syncing results)
JIRA_DOMAIN=https://your-domain.atlassian.net
JIRA_USER_EMAIL=your_jira_mail@exemplo.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_ISSUE_KEY=TEST-123

# Scheduling (Optional)
# Format HH:MM (24h). If set, the script will wait until this time to run.
DAILY_EXECUTION_TIME=14:54

# Test Tags (Optional)
# This will be injected by GitLab/Jira to indicate which tags were requested.
# It is used to correctly identify skipped tests in the Jira report.
TEST_TAGS=CT01 CT02